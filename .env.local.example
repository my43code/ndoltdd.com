MONGODB_URI=mongodb://127.0.0.1:27017/myweb6
NEXTAUTH_SECRET=replace-with-a-long-random-secret
NEXTAUTH_URL=http://localhost:3000
ADMIN_NAME=Site Admin
ADMIN_EMAILS=admin@example.com
ADMIN_PHONES=+1234567890
ADMIN_PASSWORD=change-this-password
OTP_DELIVERY_MODE=email
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=no-reply@example.com
OTP_SMS_WEBHOOK_URL=https://your-sms-provider-webhook.example/send-code

# Optional: connect YuTok to any OpenAI-compatible chat-completions provider.
# Without these values, YuTok still answers from site knowledge, dictionary,
# and encyclopedia lookups.
YUTOK_AI_API_KEY=
YUTOK_AI_BASE_URL=https://api.openai.com/v1
YUTOK_AI_MODEL=
